FROM python:3.12-slim

WORKDIR /app

# Copy project files
COPY pyproject.toml VERSION README.md ./
COPY toonic/ toonic/

# Install minimal dependencies (no video/audio)
RUN pip install --no-cache-dir -e ".[server,llm]"

# Verify installation
RUN python -c "import toonic; print(f'Toonic {toonic.__version__} installed')" && \
    python -c "from toonic.server.triggers import TriggerScheduler; print('Triggers OK')" && \
    python -c "import fastapi, uvicorn, yaml, httpx; print('Server deps OK')"

CMD ["python", "-m", "toonic.server", "--help"]
